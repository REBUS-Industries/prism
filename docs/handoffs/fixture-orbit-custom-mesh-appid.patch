+  const sMeta = (stored.metadata ?? {}) as Record<string, unknown>;
+  const iMeta = { ...(incoming.metadata ?? {}) } as Record<string, unknown>;
+  iMeta.mediaId = sMeta.mediaId;
+  iMeta.replaced = true;
