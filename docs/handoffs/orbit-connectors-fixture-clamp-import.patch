diff --git a/src/OrbitConnector.Rhino/Library/FixtureClampHelper.cs b/src/OrbitConnector.Rhino/Library/FixtureClampHelper.cs
new file mode 100644
index 0000000..71d076b
--- /dev/null
+++ b/src/OrbitConnector.Rhino/Library/FixtureClampHelper.cs
@@ -0,0 +1,93 @@
+using Newtonsoft.Json.Linq;
+
+namespace OrbitConnector.Rhino.Library;
+
+/// <summary>
+/// Clamp mesh detection + import filtering for fixture receive.
+/// PRISM stamps <c>partTag: "CLAMP"</c> and <c>isClamp: true</c> on clamp
+/// meshes / part collections at Orbit publish time.
+/// </summary>
+public static class FixtureClampHelper
+{
+    private static readonly string[] PartTagKeys = { "partTag", "gdtfTag", "tag", "prism:partTag" };
+
+    /// <summary>
+    /// True when the fixture definition (or Orbit root props) advertises clamp parts.
+    /// </summary>
+    public static bool FixtureHasClamps(JToken? definition, JToken? rootProperties = null)
+    {
+        if (rootProperties is JObject props)
+        {
+            if (props.Value<bool?>("hasClamps") == true) return true;
+            if (props["clampPartIds"] is JArray ids && ids.Count > 0) return true;
+            if (props.Value<int?>("clampPartCount") is > 0) return true;
+        }
+
+        if (definition?["parts"] is not JArray parts)
+            return false;
+
+        foreach (var token in parts)
+        {
+            if (token is not JObject part) continue;
+            if (IsClampPartTag(ReadPartTag(part))) return true;
+        }
+
+        return false;
+    }
+
+    public static bool IsClampPartTag(string? tag)
+        => string.Equals(tag?.Trim(), "CLAMP", StringComparison.OrdinalIgnoreCase);
+
+    /// <summary>
+    /// True when a wire mesh / part collection is clamp geometry.
+    /// </summary>
+    public static bool IsClampMesh(JObject node)
+    {
+        if (ReadBool(node, "isClamp") == true) return true;
+        if (node["properties"] is JObject props && ReadBool(props, "isClamp") == true)
+            return true;
+
+        return IsClampPartTag(ReadPartTag(node));
+    }
+
+    /// <summary>
+    /// Include the mesh when importing with clamps, or when it is not a clamp mesh.
+    /// </summary>
+    public static bool MeshVisibleForClamps(JObject mesh, bool includeClamps)
+    {
+        if (includeClamps) return true;
+        return !IsClampMesh(mesh);
+    }
+
+    private static string? ReadPartTag(JObject node)
+    {
+        foreach (var key in PartTagKeys)
+        {
+            var v = node[key]?.Value<string>();
+            if (!string.IsNullOrWhiteSpace(v)) return v.Trim();
+        }
+
+        if (node["properties"] is JObject props)
+        {
+            foreach (var key in PartTagKeys)
+            {
+                var v = props[key]?.Value<string>();
+                if (!string.IsNullOrWhiteSpace(v)) return v.Trim();
+            }
+        }
+
+        return null;
+    }
+
+    private static bool? ReadBool(JObject node, string key)
+    {
+        var token = node[key];
+        return token?.Type switch
+        {
+            JTokenType.Boolean => token.Value<bool>(),
+            JTokenType.Integer => token.Value<int>() != 0,
+            JTokenType.String => bool.TryParse(token.Value<string>(), out var b) ? b : null,
+            _ => null,
+        };
+    }
+}
