@@ -0,0 +1,56 @@
+using Newtonsoft.Json.Linq;
+using OrbitConnector.Rhino.Library;
+using Xunit;
+
+namespace OrbitConnector.Rhino.Tests.Fixtures;
+
+public class FixtureClampHelperTests
+{
+    [Fact]
+    public void IsClampMesh_reads_isClamp_flag()
+    {
+        var mesh = new JObject { ["isClamp"] = true, ["partTag"] = "BASE" };
+        Assert.True(FixtureClampHelper.IsClampMesh(mesh));
+    }
+
+    [Fact]
+    public void IsClampMesh_reads_partTag_CLAMP()
+    {
+        var mesh = new JObject { ["partTag"] = "CLAMP" };
+        Assert.True(FixtureClampHelper.IsClampMesh(mesh));
+        Assert.False(FixtureClampHelper.IsClampMesh(new JObject { ["partTag"] = "HEAD" }));
+    }
+
+    [Fact]
+    public void MeshVisibleForClamps_excludes_clamps_when_requested()
+    {
+        var clamp = new JObject { ["partTag"] = "CLAMP", ["isClamp"] = true };
+        var head = new JObject { ["partTag"] = "HEAD" };
+        Assert.True(FixtureClampHelper.MeshVisibleForClamps(clamp, includeClamps: true));
+        Assert.False(FixtureClampHelper.MeshVisibleForClamps(clamp, includeClamps: false));
+        Assert.True(FixtureClampHelper.MeshVisibleForClamps(head, includeClamps: false));
+    }
+
+    [Fact]
+    public void FixtureHasClamps_from_definition_parts()
+    {
+        var def = new JObject
+        {
+            ["parts"] = new JArray(
+                new JObject { ["partId"] = "base", ["tag"] = "BASE" },
+                new JObject { ["partId"] = "rebus-clamp-part", ["tag"] = "CLAMP" }),
+        };
+        Assert.True(FixtureClampHelper.FixtureHasClamps(def));
+        Assert.False(FixtureClampHelper.FixtureHasClamps(new JObject
+        {
+            ["parts"] = new JArray(new JObject { ["partId"] = "base", ["tag"] = "BASE" }),
+        }));
+    }
+
+    [Fact]
+    public void FixtureHasClamps_from_root_properties()
+    {
+        var props = new JObject { ["hasClamps"] = true, ["clampPartIds"] = new JArray("c1") };
+        Assert.True(FixtureClampHelper.FixtureHasClamps(definition: null, rootProperties: props));
+    }
+}
