diff --git a/src/fixtures/mergeDefinitionPreservingModels.test.ts b/src/fixtures/mergeDefinitionPreservingModels.test.ts
index 9aef89f..b43345c 100644
--- a/src/fixtures/mergeDefinitionPreservingModels.test.ts
+++ b/src/fixtures/mergeDefinitionPreservingModels.test.ts
@@ -76,16 +76,28 @@ function def(partial: Partial<FixtureDefinition>): FixtureDefinition {
 
 {
   // Stale save must not clobber a just-replaced mesh with pre-replace media.
+  // Client meshOffset / dim edits on that model are still kept.
   const stored = def({
     models: [model('base', 'media-replaced', true), model('head', 'media-head')],
   });
+  const incomingBase = model('base', 'media-stale');
+  (incomingBase.metadata as Record<string, unknown>).meshOffset = {
+    position: { x: 0.01, y: 0, z: 0 },
+    rotation: { x: 0, y: 0, z: 0 },
+  };
+  (incomingBase.metadata as Record<string, unknown>).length = 0.25;
   const incoming = def({
-    models: [model('base', 'media-stale'), model('head', 'media-head')],
+    models: [incomingBase, model('head', 'media-head')],
   });
   const merged = mergeDefinitionPreservingModels(stored, incoming);
   const base = merged.models.find((m) => m.modelId === 'base')!;
   assert.equal(base.metadata.mediaId, 'media-replaced');
   assert.equal(base.metadata.replaced, true);
+  assert.equal((base.metadata as { length?: number }).length, 0.25);
+  assert.deepEqual(
+    (base.metadata as { meshOffset?: unknown }).meshOffset,
+    { position: { x: 0.01, y: 0, z: 0 }, rotation: { x: 0, y: 0, z: 0 } },
+  );
 }
 
 {
diff --git a/src/fixtures/mergeDefinitionPreservingModels.ts b/src/fixtures/mergeDefinitionPreservingModels.ts
index 8080417..2ee3c69 100644
--- a/src/fixtures/mergeDefinitionPreservingModels.ts
+++ b/src/fixtures/mergeDefinitionPreservingModels.ts
@@ -12,7 +12,8 @@ import type { FixtureDefinition, FixtureModel } from '@rebus-industries/prism-sh
  * Rules:
  * - Incoming wins for entries present in both, except when the stored model is
  *   a `replaced` mesh whose mediaId the incoming payload does not reflect —
- *   then keep the stored replacement.
+ *   then keep the stored replacement **media wiring** while still applying the
+ *   client's meshOffset / dim / flip edits onto that model.
  * - Models/parts/beams/motion axes/wheels that exist only on the server are
  *   appended.
  * - All other top-level definition fields come from the incoming payload.
@@ -23,12 +24,7 @@ export function mergeDefinitionPreservingModels(
 ): FixtureDefinition {
   const result = structuredClone(incoming) as FixtureDefinition;
 
-  result.models = mergeById(
-    stored.models ?? [],
-    result.models ?? [],
-    (m) => m.modelId,
-    preferStoredReplacement,
-  );
+  result.models = mergeModels(stored.models ?? [], result.models ?? []);
   result.parts = mergeById(
     stored.parts ?? [],
     result.parts ?? [],
@@ -57,23 +53,33 @@ function mergeById<T>(
   stored: T[],
   incoming: T[],
   idOf: (row: T) => string,
-  preferStored?: (stored: T, incoming: T) => boolean,
 ): T[] {
   const incomingById = new Map(incoming.map((row) => [idOf(row), row]));
-  const storedById = new Map(stored.map((row) => [idOf(row), row]));
+  const merged = [...incoming];
+  for (const s of stored) {
+    if (!incomingById.has(idOf(s))) merged.push(structuredClone(s));
+  }
+  return merged;
+}
+
+function mergeModels(stored: FixtureModel[], incoming: FixtureModel[]): FixtureModel[] {
+  const incomingById = new Map(incoming.map((m) => [m.modelId, m]));
+  const storedById = new Map(stored.map((m) => [m.modelId, m]));
   const merged = incoming.map((row) => {
-    const s = storedById.get(idOf(row));
-    if (s && preferStored?.(s, row)) return structuredClone(s);
+    const s = storedById.get(row.modelId);
+    if (s && storedReplacementMediaStaleOnClient(s, row)) {
+      return applyStoredReplacementMedia(s, row);
+    }
     return row;
   });
   for (const s of stored) {
-    if (!incomingById.has(idOf(s))) merged.push(structuredClone(s));
+    if (!incomingById.has(s.modelId)) merged.push(structuredClone(s));
   }
   return merged;
 }
 
 /** True when stored has a replaced mesh the incoming payload has not caught up to. */
-function preferStoredReplacement(stored: FixtureModel, incoming: FixtureModel): boolean {
+function storedReplacementMediaStaleOnClient(stored: FixtureModel, incoming: FixtureModel): boolean {
   const sMeta = (stored.metadata ?? {}) as Record<string, unknown>;
   const iMeta = (incoming.metadata ?? {}) as Record<string, unknown>;
   if (sMeta.replaced !== true) return false;
@@ -82,3 +88,21 @@ function preferStoredReplacement(stored: FixtureModel, incoming: FixtureModel):
   const iMedia = typeof iMeta.mediaId === 'string' ? iMeta.mediaId : null;
   return iMedia !== sMedia;
 }
+
+/**
+ * Keep the client's transforms/offsets/dims, but force the stored custom-mesh
+ * mediaId / replaced flags / storagePath so a stale save cannot revert to GDTF.
+ */
+function applyStoredReplacementMedia(stored: FixtureModel, incoming: FixtureModel): FixtureModel {
+  const sMeta = (stored.metadata ?? {}) as Record<string, unknown>;
+  const iMeta = { ...(incoming.metadata ?? {}) } as Record<string, unknown>;
+  iMeta.mediaId = sMeta.mediaId;
+  iMeta.replaced = true;
+  if (typeof sMeta.replacedFilename === 'string') iMeta.replacedFilename = sMeta.replacedFilename;
+  if (typeof sMeta.sourceFilename === 'string') iMeta.sourceFilename = sMeta.sourceFilename;
+  const next: FixtureModel = { ...incoming, metadata: iMeta };
+  if (typeof stored.storagePath === 'string' && stored.storagePath) {
+    next.storagePath = stored.storagePath;
+  }
+  return next;
+}
diff --git a/src/import/backfillReplacedModelDims.ts b/src/import/backfillReplacedModelDims.ts
index b824712..c10954c 100644
--- a/src/import/backfillReplacedModelDims.ts
+++ b/src/import/backfillReplacedModelDims.ts
@@ -67,6 +67,13 @@ function restoreSlotDimsInto(
     // retrying on the next serve/publish.
     if (!restored) continue;
     delete next[MESH_MEASURED_KEY];
+    // meshOffset / ignoreImportedMeshDatum were often computed while dims were
+    // the authored mesh bbox (scale ≈ 1). After restoring GDTF slot dims the
+    // fit scale changes, so those offsets are no longer valid — drop them so
+    // Orbit/preview don't bake a double-compensated XYZ. Users can re-enable
+    // "Ignore imported mesh datum" to realign.
+    delete next.meshOffset;
+    delete next.ignoreImportedMeshDatum;
     model.metadata = next;
     changed = true;
   }
diff --git a/src/import/fixtureEditCarryForward.ts b/src/import/fixtureEditCarryForward.ts
index a55c6f2..df31918 100644
--- a/src/import/fixtureEditCarryForward.ts
+++ b/src/import/fixtureEditCarryForward.ts
@@ -88,5 +88,39 @@ export function carryForwardEdits(
     report.applied.push('displayName');
   }
 
+  // Preserve custom replaced meshes across reimport / version carry. Fresh GDTF
+  // registration always wires GDTF mediaIds; without this, Settings → Replace
+  // uploads vanish on quality switch and Orbit publishes the stock head/base.
+  const workModels = new Map((workingDef.models ?? []).map((m) => [m.modelId, m]));
+  for (const model of result.models ?? []) {
+    const work = workModels.get(model.modelId);
+    if (!work) continue;
+    const wMeta = (work.metadata ?? {}) as Record<string, unknown>;
+    if (wMeta.replaced !== true) continue;
+    const mediaId = typeof wMeta.mediaId === 'string' ? wMeta.mediaId : null;
+    if (!mediaId) continue;
+
+    const nextMeta: Record<string, unknown> = {
+      ...(model.metadata ?? {}),
+      mediaId,
+      replaced: true,
+    };
+    if (typeof wMeta.replacedFilename === 'string') nextMeta.replacedFilename = wMeta.replacedFilename;
+    if (typeof wMeta.sourceFilename === 'string') nextMeta.sourceFilename = wMeta.sourceFilename;
+    if (wMeta.meshOffset && typeof wMeta.meshOffset === 'object') {
+      nextMeta.meshOffset = structuredClone(wMeta.meshOffset);
+    }
+    if (wMeta.ignoreImportedMeshDatum === true) nextMeta.ignoreImportedMeshDatum = true;
+    if (wMeta.gdtfBounds && typeof wMeta.gdtfBounds === 'object') {
+      nextMeta.gdtfBounds = structuredClone(wMeta.gdtfBounds);
+    }
+    if (wMeta.flipNormals === true) nextMeta.flipNormals = true;
+    model.metadata = nextMeta;
+    if (typeof work.storagePath === 'string' && work.storagePath) {
+      model.storagePath = work.storagePath;
+    }
+    report.applied.push(`model:${model.modelId}:custom-mesh`);
+  }
+
   return { definition: result, report };
 }
