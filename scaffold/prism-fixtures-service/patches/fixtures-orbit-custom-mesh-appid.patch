@@ -373,6 +374,13 @@ const plugin: FastifyPluginAsync = async (app) => {
     }
 
     const [row] = await db.update(fixtureTypes).set(patch).where(eq(fixtureTypes.id, id)).returning();
+    // Keep the active version snapshot aligned with the working definition so
+    // quality switches / version ops don't resurrect pre-replace GDTF media.
+    if (patch.definition && row?.activeVersionId) {
