+/** Re-import the active GDTF revision/package and discard all user edits. */
+export async function resetFixtureToGdtf(
+  fixtureTypeId: string,
+  principal: Principal | undefined,
+  modelQuality?: GdtfModelQuality,
+): Promise<{ fixture: typeof fixtureTypes.$inferSelect }> {
+  const ftRows = await db.select().from(fixtureTypes)
+    .where(and(eq(fixtureTypes.id, fixtureTypeId), isNull(fixtureTypes.deletedAt)))
+    .limit(1);
+  const ft = ftRows[0];
+  if (!ft) throw new Error('fixture not found');
+
+  if (ft.activeVersionId) {
+    const av = await db.select().from(fixtureVersions)
+      .where(eq(fixtureVersions.id, ft.activeVersionId)).limit(1);
+    const shareRid = av[0]?.gdtfShareRid;
+    if (shareRid) {
+      const result = await downloadNewVersion(fixtureTypeId, shareRid, principal, false, modelQuality);
+      return { fixture: result.fixture };
+    }
+  }
+
+  const quality = modelQuality ?? 'default';
+  const result = await reimportFixtureMeshes(fixtureTypeId, quality, false);
+  return { fixture: result.fixture };
+}
