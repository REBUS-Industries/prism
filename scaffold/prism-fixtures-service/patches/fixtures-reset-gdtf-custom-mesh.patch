+import assert from 'node:assert/strict';
+import { definitionAfterGdtfReset } from '../import/gdtfResetHelpers.js';
+
+const reset = definitionAfterGdtfReset({
+  fixtureInformation: { manufacturer: 'M', fixtureName: 'F' },
+  parts: [],
+  models: [{
+    modelId: 'body',
+    name: 'Body',
+    metadata: {
+      mediaId: 'old-media',
+      replaced: true,
+      replacedFilename: 'custom.glb',
+      meshOffset: { position: { x: 1, y: 0, z: 0 }, rotation: { x: 0, y: 0, z: 0 } },
+      sourceFile: 'models/body.gltf',
+    },
+  }],
+  metadata: { displayName: 'Pretty name' },
+} as never);
+
+assert.equal((reset.metadata as Record<string, unknown>).displayName, undefined);
+assert.equal(reset.models?.[0]?.metadata?.replaced, undefined);
+assert.equal(reset.models?.[0]?.metadata?.meshOffset, undefined);
+assert.equal(reset.models?.[0]?.metadata?.mediaId, 'old-media');
+console.log('gdtfResetHelpers.test ok');
diff --git a/src/import/gdtfResetHelpers.ts b/src/import/gdtfResetHelpers.ts
new file mode 100644
index 0000000..91b78a3
--- /dev/null
+++ b/src/import/gdtfResetHelpers.ts
@@ -0,0 +1,33 @@
+import type { FixtureDefinition } from '@rebus-industries/prism-shared';
+
+const USER_MODEL_METADATA_KEYS = [
+  'replaced',
+  'replacedFilename',
+  'meshOffset',
+  'flipNormals',
+] as const;
+
+const USER_FIXTURE_METADATA_KEYS = [
+  'displayName',
+] as const;
+
+/** Drop PRISM user edits from a freshly parsed GDTF definition before persisting a reset. */
+export function definitionAfterGdtfReset(def: FixtureDefinition): FixtureDefinition {
+  const result = structuredClone(def) as FixtureDefinition;
+
+  if (result.metadata && typeof result.metadata === 'object') {
+    const meta = { ...(result.metadata as Record<string, unknown>) };
+    for (const key of USER_FIXTURE_METADATA_KEYS) delete meta[key];
+    result.metadata = meta;
+  }
+
+  for (const model of result.models ?? []) {
+    if (model.metadata && typeof model.metadata === 'object') {
+      const meta = { ...(model.metadata as Record<string, unknown>) };
+      for (const key of USER_MODEL_METADATA_KEYS) delete meta[key];
+      model.metadata = meta;
+    }
+  }
+
+  return result;
+}
