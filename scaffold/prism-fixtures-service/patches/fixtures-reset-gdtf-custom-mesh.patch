+/** True when the model mesh was swapped via Settings → Replace. */
+export function isCustomReplacedModel(model: { metadata?: unknown } | null | undefined): boolean {
+  const meta = (model?.metadata ?? {}) as { replaced?: unknown };
+  return meta.replaced === true;
