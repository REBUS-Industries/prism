diff --git a/src/fixtures/fixtureIesProfiles.ts b/src/fixtures/fixtureIesProfiles.ts
new file mode 100644
index 0000000..ebf71ac
--- /dev/null
+++ b/src/fixtures/fixtureIesProfiles.ts
@@ -0,0 +1,12 @@
+import type { FixtureDefinition } from '@rebus-industries/prism-shared';
+
+function iesProfileCount(beam: { iesProfiles?: { iesAssetId: string }[]; iesAssetId?: string | null }): number {
+  let n = (beam.iesProfiles ?? []).length;
+  if (!n && beam.iesAssetId) n = 1;
+  return n;
+}
+
+/** True when any beam carries an uploaded IES profile (legacy or zoom-keyed). */
+export function fixtureHasIesProfiles(definition: FixtureDefinition | null | undefined): boolean {
+  return (definition?.beams ?? []).some((b) => iesProfileCount(b) > 0);
+}
