diff --git a/src/fixtures/fixtureCustomMesh.ts b/src/fixtures/fixtureCustomMesh.ts
new file mode 100644
index 0000000..ee754fa
--- /dev/null
+++ b/src/fixtures/fixtureCustomMesh.ts
@@ -0,0 +1,9 @@
+import type { FixtureDefinition } from '@rebus-industries/prism-shared';
+
+/** True when any model carries a custom replaced mesh (`metadata.replaced`). */
+export function fixtureHasCustomMeshes(definition: FixtureDefinition | null | undefined): boolean {
+  return (definition?.models ?? []).some((m) => {
+    const meta = m.metadata as { replaced?: unknown } | undefined;
+    return meta?.replaced === true;
+  });
+}
