+import assert from 'node:assert/strict';
+import { readFixtureOrbitRef, resolveFixtureOrbitUrl } from './fixtureOrbitUrl.js';
+
+const definition = {
+  fixtureInformation: { manufacturer: 'ACME', fixtureName: 'Test' },
+  parts: [],
+  models: [],
+  beams: [],
+  motionRig: [],
+  wheels: [],
+  dmxMapping: {},
+  metadata: {
+    orbitFixtureRef: {
+      target: 'prod',
+      projectId: '0f2893eb28',
+      modelId: 'abc123',
+      versionId: 'ver456',
+      objectId: 'obj789',
+      publishedAt: '2026-07-01T00:00:00.000Z',
+    },
+  },
+};
+
+assert.equal(readFixtureOrbitRef(definition)?.modelId, 'abc123');
+assert.equal(
+  resolveFixtureOrbitUrl(definition),
+  'https://orbit.rebus.industries/projects/0f2893eb28/models/abc123',
+);
+
+assert.equal(
+  resolveFixtureOrbitUrl({
+    ...definition,
+    metadata: {
+      orbitFixtureRef: {
+        ...definition.metadata.orbitFixtureRef,
+        orbitUrl: 'https://orbit.rebus.industries/projects/0f2893eb28/models/custom',
+      },
+    },
+  }),
+  'https://orbit.rebus.industries/projects/0f2893eb28/models/custom',
+);
+
+assert.equal(resolveFixtureOrbitUrl({ ...definition, metadata: {} }), null);
+
+console.log('fixtureOrbitUrl.test: ok');
diff --git a/src/fixtures/fixtureOrbitUrl.ts b/src/fixtures/fixtureOrbitUrl.ts
new file mode 100644
index 0000000..7385c35
--- /dev/null
+++ b/src/fixtures/fixtureOrbitUrl.ts
@@ -0,0 +1,58 @@
+import type { FixtureDefinition } from '@rebus-industries/prism-shared';
+
+type FixtureOrbitRef = {
+  target: 'prod' | 'dev';
+  projectId: string;
+  modelId: string;
+  versionId: string;
+  objectId: string;
+  publishedAt: string;
+  orbitUrl?: string;
+};
+
+const DEFAULT_ORBIT_SERVER_URLS = {
+  prod: 'https://orbit.rebus.industries',
+  dev: 'https://orbit-dev.rebus.industries',
+} as const;
+
+export function readFixtureOrbitRef(
+  definition?: FixtureDefinition | Record<string, unknown> | null,
+): FixtureOrbitRef | null {
+  const meta = (definition as FixtureDefinition | undefined)?.metadata;
+  if (!meta || typeof meta !== 'object') return null;
+  const raw = (meta as Record<string, unknown>).orbitFixtureRef;
+  if (!raw || typeof raw !== 'object') return null;
+  const bag = raw as Record<string, unknown>;
+  const projectId = typeof bag.projectId === 'string' ? bag.projectId.trim() : '';
+  const modelId = typeof bag.modelId === 'string' ? bag.modelId.trim() : '';
+  const versionId = typeof bag.versionId === 'string' ? bag.versionId.trim() : '';
+  const objectId = typeof bag.objectId === 'string' ? bag.objectId.trim() : '';
+  if (!projectId || !modelId || !versionId || !objectId) return null;
+  return {
+    target: bag.target === 'dev' ? 'dev' : 'prod',
+    projectId,
+    modelId,
+    versionId,
+    objectId,
+    publishedAt: typeof bag.publishedAt === 'string' ? bag.publishedAt : '',
+    orbitUrl: typeof bag.orbitUrl === 'string' && bag.orbitUrl.trim() ? bag.orbitUrl.trim() : undefined,
+  };
+}
+
+export function resolveFixtureOrbitUrl(
+  definition?: FixtureDefinition | Record<string, unknown> | null,
+): string | null {
+  const ref = readFixtureOrbitRef(definition);
+  if (!ref) return null;
+  if (ref.orbitUrl) return ref.orbitUrl;
+  const base = DEFAULT_ORBIT_SERVER_URLS[ref.target as 'prod' | 'dev'];
+  return `${base}/projects/${ref.projectId}/models/${ref.modelId}`;
+}
+
+export function resolveFixturePreviewUrl(
+  fixtureId: string,
+  previewModelId: string | null | undefined,
+): string | null {
+  if (!previewModelId) return null;
+  return `/api/fixtures/${fixtureId}/preview.glb`;
+}
