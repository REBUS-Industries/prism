@@ -82,6 +82,45 @@ function translationOf(m: number[]): Vec3 {
   return { x: m[3] ?? 0, y: m[7] ?? 0, z: m[11] ?? 0 };
 }
 
+/**
+ * Per-mesh placement offset for a fixture model (GDTF Z-up metres + degrees
+ * XYZ). Applied on top of the part world transform WITHOUT changing it, so the
+ * pan/tilt pivot is preserved. Mirrors the web `fixtureTransform.MeshOffset`.
+ */
+export interface MeshOffset {
+  position: Vec3;
+  rotation: Vec3;
+}
+
+function readVec3(raw: unknown): Vec3 {
+  const b = (raw ?? {}) as Record<string, unknown>;
+  return {
+    x: typeof b.x === 'number' ? b.x : 0,
+    y: typeof b.y === 'number' ? b.y : 0,
+    z: typeof b.z === 'number' ? b.z : 0,
+  };
+}
+
+/** Read `model.metadata.meshOffset`; returns null when absent or all-zero. */
+export function readMeshOffset(metadata: Record<string, unknown> | null | undefined): MeshOffset | null {
+  const raw = (metadata ?? {})['meshOffset'];
+  if (!raw || typeof raw !== 'object') return null;
+  const bag = raw as Record<string, unknown>;
+  const offset: MeshOffset = { position: readVec3(bag.position), rotation: readVec3(bag.rotation) };
+  const { position: p, rotation: r } = offset;
+  if (p.x === 0 && p.y === 0 && p.z === 0 && r.x === 0 && r.y === 0 && r.z === 0) return null;
+  return offset;
+}
+
+/**
+ * Row-major offset matrix (Translate · Rotate XYZ) applied in the part-local
+ * GDTF frame. Compose into the placement as `world · meshOffsetMatrixRow(offset)`
+ * so the published mesh matches the web viewer (partWorld · offset · wrap · scale).
+ */
+export function meshOffsetMatrixRow(offset: MeshOffset): number[] {
+  return composeMatrixFromTrs(offset.position, offset.rotation, { x: 1, y: 1, z: 1 });
+}
