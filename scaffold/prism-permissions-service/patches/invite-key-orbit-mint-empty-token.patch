       projectIds,
     };
-  } catch {
+  } catch (err) {
+    // Invite keys need the underlying Orbit error (forbidAdminFallback).
+    // Portal / full-connector path keeps soft-fail ‚Üí null ‚Üí empty token + admin fallback inside mint.
+    if (input.forbidAdminFallback) throw err;
     return null;
   }
 }
@@ -282,6 +286,9 @@ export async function exchangeInviteKeySession(body: AccessSessionRequest & { in
     level: 'contributor' as const,
     projectName: key.projectNames[orbitProjectId] ?? null,
   }));
+  if (projects.length === 0) {
+    throw new AccessError('Invite key has no Orbit projects ‚Äî cannot mint a scoped token', 400);
+  }
 
   const sessionId = randomUUID();
   const expiresAt = sessionExpiry();
@@ -296,21 +303,40 @@ export async function exchangeInviteKeySession(body: AccessSessionRequest & { in
   const linkId = await upsertIdentityLink(syntheticUser, orbitUserId);
   await cacheProjectPermissions(orbitUserId, projects);
 
-  const minted = await tryMintOrbitToken({
-    orbitTarget,
-    portalUser: syntheticUser,
-    projects,
-    sessionId,
-    blanket: false,
-    fixedFunctions: key.allowedFunctions,
-    forbidAdminFallback: true,
-  });
+  // Invite keys require a real scoped Orbit PAT (limitResources = key projects).
+  // Never return 200 with an empty orbitToken ‚Äî the Lite connector cannot log in.
+  let minted: Awaited<ReturnType<typeof tryMintOrbitToken>>;
+  try {
+    minted = await tryMintOrbitToken({
+      orbitTarget,
+      portalUser: syntheticUser,
+      projects,
+      sessionId,
+      blanket: false,
+      fixedFunctions: key.allowedFunctions,
+      forbidAdminFallback: true,
+    });
+  } catch (err) {
+    const detail = err instanceof Error ? err.message : String(err);
+    throw new AccessError(
+      `Failed to mint Orbit token for invite key (target=${orbitTarget}): ${detail}`,
+      503,
+    );
+  }
+  if (!minted?.orbitToken) {
+    throw new AccessError(
+      `Failed to mint Orbit token for invite key (target=${orbitTarget}): ` +
+        'Orbit admin credentials missing or apiTokenCreate returned no token. ' +
+        'Check ORBIT_ADMIN_TOKEN / ORBIT_SERVER_URL for this target.',
+      503,
+    );
+  }
 
   const manifest = await buildConnectorManifest({
     sessionId,
     orbitTarget,
     orbitServerUrl,
-    orbitToken: minted?.orbitToken ?? '',
+    orbitToken: minted.orbitToken,
     expiresAt,
     portalUser: syntheticUser,
     portalProjects: projects,
