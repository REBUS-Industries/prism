+ * so an empty/unscoped admin token is never returned.
  */
 export async function mintScopedOrbitToken(input: MintTokenInput): Promise<MintTokenResult> {
   const creds = getOrbitCreds(input.target);
@@ -63,20 +70,17 @@ export async function mintScopedOrbitToken(input: MintTokenInput): Promise<MintT
       scopes,
