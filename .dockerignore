# Keep the docker build context small + reproducible.
#
# The server image only needs server/, web/, shared/ — everything else
# is noise (and the submodule would be empty in CI anyway).

vendor/
agent/*
# Allow the install scripts + example config so the server image can serve
# them from /api/admin/workstations/downloads/* (see Dockerfile COPY agent/...).
!agent/install
!agent/install/**
!agent/src
agent/src/*
!agent/src/PRISM.Agent
agent/src/PRISM.Agent/*
!agent/src/PRISM.Agent/agent-config.example.json
.git/
.github/
**/node_modules/
**/dist/
**/.next/
**/coverage/
**/.cache/
**/.vscode/
**/.idea/

# Bulky web assets that are regenerated by the builder stage
web/node_modules/
web/dist/

# Server build outputs (regenerated)
server/node_modules/
server/dist/

# Local env + logs
*.log
.env
.env.*
!.env.example

# Editor noise
*.swp
*.swo
.DS_Store
Thumbs.db
