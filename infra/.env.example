# Copy to .env on VM 211 and fill in real values. NEVER commit a real .env.
#
# --- Postgres -----------------------------------------------------------
POSTGRES_USER=prism
POSTGRES_PASSWORD=changeme-strong-random
POSTGRES_DB=prism
# Dedicated database for the model library (prism-models-service). Created
# automatically at boot if it does not exist. Override only to relocate it.
POSTGRES_MODELS_DB=prism_models

# --- ORBIT server targets ------------------------------------------------
# The convert UI lists these in the prod/dev dropdown.
ORBIT_SERVER_URL=https://orbit.rebus.industries
ORBIT_DEV_SERVER_URL=

# --- Admin bootstrap ------------------------------------------------------
# Used to seed admin_users on first boot if the table is empty.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme-strong-random

# --- Session cookie signing key ------------------------------------------
SESSION_SECRET=changeme-32-bytes-base64

# --- Public base URL (used to mint signed agent download/upload URLs) ---
PUBLIC_BASE_URL=https://prism.rebus.industries

# --- Image tag pins ------------------------------------------------------
# Set to a specific sha-XXXXXXX tag (or vX.Y.Z) in prod for predictable
# rollouts; both default to "latest" which tracks main.
PRISM_IMAGE_TAG=latest
PRISM_ASSIMP_TAG=latest
# Model library service image (prism-models-service).
PRISM_MODELS_TAG=latest
# Permissions service image (prism-permissions-service).
PRISM_PERMISSIONS_TAG=latest

# --- Portal / permissions (prism-permissions-service) --------------------
PORTAL_ADAPTER=mock
PORTAL_BASE_URL=https://portal.rebus.industries
PORTAL_API_KEY=
# Comma-separated Google/portal emails allowed to sign in to PRISM admin (maps to PORTAL_ADMIN_USERNAME).
PORTAL_ADMIN_EMAILS=alice@rebus.industries
PORTAL_ADMIN_USERNAME=admin
PORTAL_MOCK_PERSONA=alice
# Production: portal OAuth authorize URL (redirect_uri is derived from PUBLIC_BASE_URL).
PORTAL_GOOGLE_AUTHORIZE_URL=
# Workspace directory sync adapter: mock (dev) or google_admin_sdk (prod).
WORKSPACE_ADAPTER=mock
WORKSPACE_DOMAIN=rebus.industries
# Super-admin email impersonated by the service account for Admin SDK directory sync.
GOOGLE_WORKSPACE_ADMIN_EMAIL=
# When 1, only provisioned workspace users may sign in (connectors + admin Google login).
WORKSPACE_ENFORCE_PROVISIONED=1
# Direct Google OAuth (portal_adapter=google) — web client credentials.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_SCOPES=openid email profile
GOOGLE_SERVICE_ACCOUNT_JSON=
ORBIT_ADMIN_TOKEN=
ORBIT_DEV_ADMIN_TOKEN=
ORBIT_AUTO_INVITE=0

# --- Pre-conversion sidecar -----------------------------------------------
# In-network URL of prism-assimp.  Leave commented to disable Assimp
# pre-conversion (the orchestrator falls back to the legacy "all formats
# go to Rhino" routing).  Set to the docker-compose service URL when
# prism-assimp is running alongside prism-server.
# ASSIMP_SERVICE_URL=http://prism-assimp:8088

# --- Visualiser (Phase H — coturn + WebRTC media relay) ------------------
# These four are consumed by server/src/visualiser/turnCredentials.ts
# (TURN creds), server/src/visualiser/signallingToken.ts (signalling JWT),
# and server/src/api/visualiser.ts (start-stream timeout). See
# infra/coturn/SETUP_NOTES.md for the matching
# coturn deploy and the exact value TURN_SECRET must hold (it MUST equal
# the `static-auth-secret` in /etc/coturn/turnserver.conf on VM 211).

# Shared secret with coturn. Generate via: openssl rand -hex 32
# Leaving this empty makes the API return `turn: null` (no credentials)
# and the player falls back to STUN/LAN-only WebRTC — fine for local
# dev, broken for public-internet streaming.
TURN_SECRET=

# Public DNS hostname of the coturn server. Default matches the planned
# A record (visualiser.rebus.industries -> 185.48.165.165 -> VM 211).
TURN_REALM=visualiser.rebus.industries

# Signing key for 5-minute HS256 tokens minted by
# POST /api/visualiser/streams/:runId/signalling-token and verified by
# the WS proxy at /ws/visualiser/:runId/signalling. Generate via:
#   openssl rand -hex 32
# MUST be distinct from TURN_SECRET; rotating one does not require
# rotating the other.
JWT_SIGNALLING_SECRET=

# Lifetime (seconds) of the signalling-WS JWT minted by
# POST /streams/:runId/signalling-token. The browser re-presents this token on
# every Pixel Streaming (auto-)reconnect, so it MUST comfortably exceed a
# viewing session - the old 300s value dropped an actively-watched viewer at
# ~5 minutes the first time the socket reconnected after expiry. Default 3600
# (1h). The browser also refreshes the token proactively, so this is headroom.
JWT_SIGNALLING_TTL_SEC=3600

# How long POST /api/visualiser/streams will block waiting for the
# agent's visualisationReady event before giving up. 600000 (600s) covers
# a COLD full-editor first-open (Unreal Editor + shader compile + DDC build
# on a freshly-cached C++ template). Lean -game runs still connect in
# ~60-90s; this is only the upper bound before a run is failed.
VISUALISER_START_TIMEOUT_MS=600000

# Viewer-aware idle reaper: end a LIVE (streaming) run that has had ZERO
# connected browser viewers for this many milliseconds, reclaiming the GPU on
# the workstation. This is NOT the start timeout above — it only applies AFTER
# a run is streaming. A run is only reaped while it has no viewers; as long as
# at least one viewer holds an open signalling socket (i.e. is watching, even
# without moving the mouse/keyboard) the run is never touched. Brief reconnect
# gaps (tab reload / token refresh) reset the countdown. Set to 0 to disable
# reaping entirely. Default (when unset) is 600000 (10 minutes).
VISUALISER_IDLE_TIMEOUT_MS=600000

# --- GitHub API token (UE template / connector pull + version picker) ----
# The agent's "pull latest UE template" feature and the admin Workstations
# version dropdown call the GitHub REST API (resolve releases + assets). The
# server route GET /api/workstations/template-releases uses this token; the
# AGENT reads the same var name from its OWN environment on the workstation.
# Without a token GitHub allows only 60 requests/hour PER IP (shared, anonymous)
# and the pull/picker fail with "GitHub API rate limit exceeded". A PAT lifts
# the limit to 5000/hour. Scope: `public_repo` (or `repo` if the
# orbit-ue-template / orbit-connectors repos are private). Generate at
# https://github.com/settings/tokens. Leave empty only for low-volume dev.
PRISM_GITHUB_TOKEN=

# --- Fab marketplace import (materials editor) ---------------------------
# Epic OAuth refresh token for server-side Fab asset downloads. Search and
# preview use Fab's public API and work without this; POST /api/fab/assets/:id/import
# requires an Epic account that owns (or can claim free) the material.
#
# Obtain once via Epic's OAuth authorization-code flow (launcher public client).
# Alternatively set a short-lived FAB_EPIC_ACCESS_TOKEN (Bearer) for testing.
# Optional overrides for the public Epic launcher client (defaults match UE Launcher):
# FAB_EPIC_CLIENT_ID=
# FAB_EPIC_CLIENT_SECRET=
FAB_EPIC_REFRESH_TOKEN=
# FAB_EPIC_ACCESS_TOKEN=

# --- External material providers (materials editor) ------------------------
# Unified browse/import: GET /api/external-materials/search (Fab + Poly Haven + ambientCG).
# On the split dev stack (docker-compose.dev.yml) these routes are served by
# prism-materials — set the vars below on that service (or in the shared .env).
#
# Poly Haven — public API, no API key; User-Agent header is mandatory per
# https://polyhaven.com/our-api
POLYHAVEN_ENABLED=true
POLYHAVEN_USER_AGENT=PRISM/0.3.0 (REBUS Industries; materials-import)
POLYHAVEN_TEXTURE_RESOLUTION=2k
# POLYHAVEN_API_BASE=https://api.polyhaven.com
#
# ambientCG — public API v3, no auth; downloads are pre-packaged ZIPs.
# https://docs.ambientcg.com/api/v3/assets
AMBIENTCG_ENABLED=true
AMBIENTCG_DOWNLOAD_ATTRIBUTES=2K-JPG
# AMBIENTCG_API_BASE=https://ambientcg.com/api/v3
# AMBIENTCG_THUMBNAIL_KEY=256-PNG
#
# Fab search/preview also available via /api/fab (legacy) and /api/external-materials.
# FAB_ENABLED=true
#
# Fab + Cloudflare (VM 211 prod / VM 212 dev)
# Fab search/detail runs server-side. Cloudflare blocks datacenter IPs even when
# FAB_EPIC_REFRESH_TOKEN is set (bearer auth enables import, not browse). PRISM uses
# FlareSolverr to obtain cf_clearance cookies for www.fab.com before Fab API calls.
#
# VM 212 dev (docker-compose.dev.yml): FlareSolverr runs as compose service
# "flaresolverr"; prism-materials defaults to http://flaresolverr:8191/v1.
# Do NOT use http://127.0.0.1:8191/v1 from inside a container — that is the
# container itself, not the VM host.
#
# Host-run FlareSolverr beside PRISM in Docker:
#   Windows/Mac Docker Desktop: http://host.docker.internal:8191/v1
#   Linux VM: http://172.17.0.1:8191/v1 (or docker bridge gateway IP)
# Host-run PRISM + FlareSolverr (no container): http://127.0.0.1:8191/v1
#
#   docker run -d --name flaresolverr --restart unless-stopped -p 8191:8191 \
#     ghcr.io/flaresolverr/flaresolverr:latest
# Admin → Settings → External materials mirrors these vars (DB overrides env).
FAB_FLARESOLVERR_URL=http://flaresolverr:8191/v1
#
# Optional residential egress when direct VM IP + FlareSolverr is still blocked:
# FAB_HTTP_PROXY=http://user:pass@proxy.example:8080

# --- Logging --------------------------------------------------------------
LOG_LEVEL=info
