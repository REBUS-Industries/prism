<?xml version="1.0" encoding="utf-8"?>
<!--
  Restrict NuGet restore to nuget.org only.

  The windows-latest GitHub Actions runner has McNeel's WIP feed configured
  at the machine level (HKEY_CURRENT_USER NuGet sources or a global NuGet.Config).
  That feed publishes pre-release RhinoCommon builds such as 8.0.25051.305-wip
  which satisfies the 8.* wildcard but is OLDER than the 8.31.x releases that
  Rhino.Inside requires — producing a spurious NU1605 downgrade error.

  <clear /> removes all inherited sources so only nuget.org is used.  This is
  picked up automatically when dotnet restore runs from the agent/ directory.
-->
<configuration>
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
  </packageSources>
</configuration>
