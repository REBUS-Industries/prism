{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "rebus/portal-access/v1",
  "title": "PortalAccess",
  "description": "REBUS portal integration + connector permissions manifest",
  "definitions": {
    "ConnectorFunction": {
      "type": "string",
      "enum": [
        "send",
        "receive",
        "list_projects",
        "list_models",
        "list_versions",
        "create_model",
        "create_version",
        "use_library",
        "use_infile"
      ]
    },
    "PortalProjectLevel": {
      "type": "string",
      "enum": ["viewer", "contributor", "owner", "admin"]
    },
    "PortalRole": {
      "type": "object",
      "required": ["id"],
      "properties": {
        "id": { "type": "string", "description": "Canonical role id matched against PortalUser.role/customRoleId and tool-grant keys." },
        "name": { "type": "string", "description": "Human-readable label (defaults to id)." },
        "system": { "type": "boolean", "description": "True for built-in portal system roles." }
      }
    },
    "PortalRolesResponse": {
      "type": "object",
      "required": ["roles", "supported", "fetchedAt"],
      "properties": {
        "roles": { "type": "array", "items": { "$ref": "#/definitions/PortalRole" } },
        "supported": { "type": "boolean", "description": "False when the portal has not implemented GET /portal/roles yet." },
        "fetchedAt": { "type": "string", "format": "date-time" }
      }
    },
    "InviteModelAccess": {
      "type": "string",
      "enum": ["all", "selected", "authored"]
    },
    "ConnectorManifest": {
      "type": "object",
      "required": ["schema", "userId", "email", "orbitTarget", "orbitServerUrl", "orbitToken", "expiresAt", "sessionId", "projects", "globalAllowedFunctions"],
      "properties": {
        "schema": { "const": "rebus/connector-manifest/v1" },
        "userId": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "orbitTarget": { "enum": ["prod", "dev"] },
        "orbitServerUrl": { "type": "string", "format": "uri" },
        "orbitToken": { "type": "string" },
        "expiresAt": { "type": "string", "format": "date-time" },
        "sessionId": { "type": "string" },
        "prismAccessToken": { "type": "string" },
        "orbitBlanketAccess": { "type": "boolean" },
        "authMethod": { "enum": ["portal", "invite_key"] },
        "inviteKeyId": { "type": "string" },
        "modelAccess": { "$ref": "#/definitions/InviteModelAccess" },
        "selectedModelIds": { "type": "array", "items": { "type": "string" } },
        "authoredProperty": { "const": "userId" },
        "projects": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["orbitProjectId", "level", "allowedFunctions"],
            "properties": {
              "orbitProjectId": { "type": "string" },
              "projectName": { "type": "string" },
              "level": { "$ref": "#/definitions/PortalProjectLevel" },
              "allowedFunctions": {
                "type": "array",
                "items": { "$ref": "#/definitions/ConnectorFunction" }
              }
            }
          }
        },
        "globalAllowedFunctions": {
          "type": "array",
          "items": { "$ref": "#/definitions/ConnectorFunction" }
        }
      }
    }
  }
}
